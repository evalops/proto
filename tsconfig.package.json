{
  "compilerOptions": {
    "rootDir": "gen/ts",
    "outDir": "gen/dist",
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "declaration": true,
    "declarationMap": false,
    "sourceMap": false,
    "skipLibCheck": true,
    "strict": true,
    "verbatimModuleSyntax": true
  },
  "include": [
    "gen/ts/**/*.ts"
  ]
}
